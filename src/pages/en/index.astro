---
import Header from '../../components/Header.astro';
import LandingPage from '../../components/LandingPage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const content = {
  hero: {
    eyebrow: 'Websites · landing pages · custom systems',
    lines: [
      { text: 'Website development.' },
      { text: 'Built for business.', accent: true },
    ],
    lead: 'Business websites, landing pages and custom systems — for better enquiries and fewer manual loops.',
    primaryCta: 'Let’s see what is worth changing',
    secondaryCta: 'Explore the solutions',
    note: 'A relaxed first conversation · reply within one business day',
    flowLabels: ['clear offer', 'trust', 'next step'],
    ticker: ['Websites', 'Landing pages', 'Custom systems', 'Clear offer', 'Better operations'],
  },
  diagnostic: {
    eyebrow: 'First, we look at the situation',
    title: 'A website either helps a decision. Or gets in the way.',
    intro: 'We find where visitor attention or team time is being lost today.',
    items: [
      { number: '01', question: 'You have a website, but it is not creating enough enquiries.', answer: 'When the offer is unclear, proof is missing or the next step is hard to find, visitors move on.' },
      { number: '02', question: 'You need a focused campaign landing page.', answer: 'A landing page should help the right visitor make one useful next step.' },
      { number: '03', question: 'Too much work still lives in spreadsheets and email.', answer: 'A well-planned internal tool shortens slow, repetitive manual work.' },
    ],
  },
  solutions: {
    eyebrow: 'What we build',
    title: 'Two paths. One goal: easier growth.',
    intro: 'Whether visibility or operations need fixing, we start from the real business situation.',
    items: [
      {
        kind: 'web', number: '01', outcome: 'Better enquiries', service: 'Websites and landing pages',
        title: 'An interface that gives direction.',
        text: 'We clarify what a visitor needs to understand, then build the page and next step around it.',
        bullets: ['Offer and message', 'Structure', 'Fast, mobile-first website'],
      },
      {
        kind: 'system', number: '02', outcome: 'Fewer manual loops', service: 'Custom web development',
        title: 'Fewer manual loops. Better operations.',
        text: 'Client portals, admin tools or data connections start from the real workflow, not a pre-made box.',
        bullets: ['Workflow map', 'Prototype', 'Custom web application'],
      },
    ],
  },
  work: {
    eyebrow: 'Real work',
    title: 'Főnix Box Club — a distinctive online presence.',
    intro: 'A website that conveys the club’s atmosphere and gives visitors a quick route to information and contact.',
    liveLabel: 'Visit the live website',
    imageAlt: 'The Főnix Box Club website home page',
    client: 'Főnix Box Club',
    clientType: 'Sports club · website + admin',
    labels: ['Starting point', 'The task', 'Solution'],
    details: [
      'The club’s character needed a consistent online expression.',
      'A quick route to essential information and contact.',
      'A distinctive mobile-first website and simple admin foundation.',
    ],
    quote: 'The web development and online presence have played a major role in helping our club reach more and more people.',
    author: 'Csaba · Főnix Box Club · translated from Hungarian',
  },
  process: {
    eyebrow: 'How an idea becomes a working tool',
    title: 'A project does not have to feel vague.',
    intro: 'At every stage, you know what we are working on and what comes out of it.',
    steps: [
      { number: '01', title: 'Understand the situation', text: 'We first clarify the goal, audience and blockage.', outcome: 'Shared direction' },
      { number: '02', title: 'Design the solution', text: 'We align the page or system plan before development starts.', outcome: 'Clear plan' },
      { number: '03', title: 'Build and test it', text: 'We build for real use, then test on mobile and desktop.', outcome: 'Usable tool' },
      { number: '04', title: 'Launch and hand over', text: 'You receive a foundation that can grow later.', outcome: 'Room to grow' },
    ],
  },
  approach: {
    eyebrow: 'Our approach',
    title: 'Not a template. A better direction.',
    intro: 'The goal is a clearer offer, a better client journey or fewer manual loops.',
    note: 'You speak directly with the people building the solution — for quick, transparent decisions.',
    principles: [
      { title: 'Visitors understand the point quickly.', text: 'The first screen is about the buyer’s situation and next step.' },
      { title: 'The team finds it easy to use.', text: 'Admin tools should make everyday work simpler.' },
      { title: 'The solution grows with the company.', text: 'Build the important first step, then expand it meaningfully.' },
    ],
  },
  testimonial: {
    eyebrow: 'Feedback',
    title: 'A good collaboration starts early.',
    quote: '“Zoli quickly understood what marketing content and advertising I needed so people would notice my business.”',
    author: 'Ádám',
    company: 'Cleancar Szolnok · translated from Hungarian',
  },
  faq: {
    eyebrow: 'FAQ',
    title: 'A few answers before we talk.',
    items: [
      { question: 'Is it worth talking if we already have a website?', answer: 'Yes. We can identify whether the offer, structure, speed or enquiry path needs improving.' },
      { question: 'When does custom software make sense?', answer: 'When a recurring process creates too much manual work or error. We clarify the workflow first.' },
      { question: 'Do you help with copy and content direction?', answer: 'Yes. We clarify the offer, audience and key messages together.' },
      { question: 'How much does a project cost?', answer: 'It depends on the objective, pages and functionality. The first conversation clarifies a sensible first step.' },
    ],
  },
  contact: {
    eyebrow: 'Initial conversation',
    title: 'Your website can do more.',
    text: 'Let’s find the best next step — website, landing page or custom development.',
    emailCta: 'Tell us about the project',
    phoneCta: 'Prefer to call',
    emailSubject: 'Initial conversation with WebsiteBusiness',
  },
  footer: {
    text: 'Websites and custom systems for growing companies.',
    legal: 'Privacy notice (HU)',
    locale: 'All rights reserved.',
    country: 'Hungary · remote collaboration',
  },
};

const title = 'Website development and custom web applications | WebsiteBusiness';
const description = 'Business website development, landing page design and custom web applications for growing companies. Clear positioning, better client journeys and smoother operations.';
const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout {title} {description} lang="en">
  <Header lang="en" />
  <LandingPage lang="en" {content} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
</BaseLayout>
