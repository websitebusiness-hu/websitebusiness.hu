---
import ArrowIcon from '../components/ArrowIcon.astro';
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    number: '01',
    icon: 'fa-bullseye',
    title: 'Ügyfélszerző weboldalak',
    text: 'Olyan weboldal, amely gyorsan bizalmat épít, érthetően mutatja be az ajánlatot és a kapcsolatfelvétel felé vezeti a látogatót.',
    features: ['Egyedi megjelenés', 'Világos ajánlat', 'Gyors kapcsolatfelvétel'],
  },
  {
    number: '02',
    icon: 'fa-window-restore',
    title: 'Webalkalmazások',
    text: 'A vállalkozás működésére szabott online rendszer, ha egy egyszerű weboldalnál többre van szükség.',
    features: ['Admin felület', 'Ügyfélportál', 'Egyedi funkciók'],
  },
  {
    number: '03',
    icon: 'fa-arrow-trend-up',
    title: 'Továbbfejlesztés',
    text: 'Meglévő weboldalak és rendszerek korszerűsítése, gyorsítása vagy új funkciókkal való bővítése.',
    features: ['Frissítés', 'Automatizálás', 'Hosszú távú támogatás'],
  },
];

const process = [
  ['01', 'fa-comments', 'Megismerjük a célt', 'Röviden átbeszéljük, mire van szüksége és mit kell megoldania a szoftvernek.'],
  ['02', 'fa-pen-ruler', 'Tervet készítünk', 'Összerakjuk a felépítést, a fő funkciókat és egy átlátható ajánlatot.'],
  ['03', 'fa-code', 'Fejlesztünk', 'Folyamatosan mutatjuk az eredményt, így végig látható, hol tart a projekt.'],
  ['04', 'fa-rocket', 'Elindítjuk', 'Tesztelés után élesítjük a rendszert, és a folytatásban sem marad egyedül.'],
];

const values = [
  {
    icon: 'fa-message',
    title: 'Érthetően kommunikálunk',
    text: 'Nincs felesleges szakzsargon. Mindig világos, mi készül, miért és mikorra.',
  },
  {
    icon: 'fa-chart-line',
    title: 'Az üzleti célt nézzük',
    text: 'Nem csak egy szép felületet adunk át. Olyan megoldást építünk, amelynek valódi szerepe van a működésben.',
  },
  {
    icon: 'fa-layer-group',
    title: 'Továbbfejleszthető alapot adunk',
    text: 'A mai kisebb projektből később nagyobb rendszer is lehet, teljes újrakezdés nélkül.',
  },
];

const title = 'Ügyfélszerző weboldal és egyedi szoftver | WebsiteBusiness';
const description =
  'Modern, ügyfélszerzésre tervezett weboldalakat, webalkalmazásokat és egyedi webes rendszereket fejlesztünk vállalkozásoknak.';
---

<BaseLayout {title} {description}>
  <Header />

  <main>
    <section id="kezdolap" class="relative overflow-hidden bg-white pt-20">
      <div class="absolute inset-x-0 top-20 h-px bg-line"></div>

      <div class="container-shell relative flex min-h-[calc(100svh-5rem)] flex-col items-center justify-start py-16 text-center md:py-20 lg:justify-center lg:py-24">
        <div class="reveal inline-flex items-center gap-2.5 border border-[#cdd7eb] bg-[#f5f8ff] px-4 py-2 text-[0.7rem] font-extrabold uppercase tracking-[0.14em] text-brand">
          <span class="size-1.5 rounded-full bg-brand"></span>
          Webfejlesztés + ügyfélszerzés · 2026
        </div>

        <h1
          class="reveal delay-1 mt-8 max-w-5xl text-[clamp(3rem,6.5vw,5.9rem)] font-semibold leading-[0.94] tracking-[-0.072em]"
          aria-label="A weboldala ne csak jelen legyen. Szerezzen ügyfeleket."
        >
          <span class="block">A weboldala ne csak</span>
          <span class="block">jelen legyen.</span>
          <span class="block text-brand">Szerezzen ügyfeleket.</span>
        </h1>

        <p class="reveal delay-2 mt-8 max-w-2xl text-lg leading-8 text-muted md:text-xl md:leading-9">
          Az ajánlatát, a weboldalt és az egyedi funkciókat egyetlen átgondolt rendszerbe építjük, hogy több látogatóból legyen valódi érdeklődő.
        </p>

        <div class="reveal delay-3 mt-10 flex w-full max-w-xl flex-col justify-center gap-3 sm:flex-row">
          <a href="#kapcsolat" class="button-primary min-h-14 flex-1 !px-6">
            Díjmentes egyeztetést kérek
            <ArrowIcon />
          </a>
          <a href="#referencia" class="button-secondary min-h-14 flex-1 !px-6">
            Megnézem az eredményt
          </a>
        </div>

        <p class="reveal delay-3 mt-5 text-sm font-semibold text-muted">
          20 perc. Konkrét ötletek. Semmi kötelezettség.
        </p>

        <div class="reveal delay-3 mt-14 flex w-full max-w-3xl flex-col items-center justify-center gap-5 border-y border-line py-5 sm:flex-row sm:gap-8">
          <span class="text-[0.68rem] font-extrabold uppercase tracking-[0.17em] text-muted">Már minket választott</span>
          <span class="hidden h-5 w-px bg-line sm:block"></span>
          <a href="#referencia" class="group flex items-center gap-3 font-extrabold">
            <img src="/images/fonix-logo.webp" width="500" height="500" alt="" class="size-9 object-contain" />
            Főnix Box Club
            <span class="text-brand transition-transform group-hover:translate-x-1"><ArrowIcon /></span>
          </a>
        </div>

        <div class="reveal delay-3 mt-8 flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm font-bold text-muted">
          <span class="flex items-center gap-2">
            <i class="fa-solid fa-bullseye text-brand" aria-hidden="true"></i>
            Üzleti célra tervezve
          </span>
          <span class="flex items-center gap-2">
            <i class="fa-solid fa-mobile-screen-button text-brand" aria-hidden="true"></i>
            Mobilon is meggyőző
          </span>
          <span class="flex items-center gap-2">
            <i class="fa-solid fa-chart-simple text-brand" aria-hidden="true"></i>
            Mérhető és bővíthető
          </span>
        </div>
      </div>
    </section>

    <section id="szolgaltatasok" class="section-space">
      <div class="container-shell">
        <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr] lg:gap-20">
          <div class="reveal">
            <p class="eyebrow">Amiben segítünk</p>
            <h2 class="section-title mt-6">A weboldalból valódi üzleti eszköz lesz.</h2>
          </div>
          <p class="section-copy reveal delay-1 lg:mt-10">
            Megértjük, mit kínál, kit szeretne elérni és miért választanák Önt. Erre építjük fel a weboldalt és a mögötte működő rendszert.
          </p>
        </div>

        <div class="mt-16 grid border-l border-t border-line md:grid-cols-3">
          {
            services.map((service, index) => (
              <article class={`reveal delay-${index + 1} flex min-h-[27rem] flex-col border-b border-r border-line p-7 transition-colors hover:bg-surface lg:p-9`}>
                <div class="flex items-center justify-between">
                  <span class="text-xs font-extrabold tracking-[0.16em] text-brand">{service.number}</span>
                  <span class="flex size-12 items-center justify-center bg-[#eaf0ff] text-lg text-brand">
                    <i class={`fa-solid ${service.icon}`} aria-hidden="true"></i>
                  </span>
                </div>
                <h3 class="mt-12 text-2xl font-semibold tracking-[-0.035em] lg:text-3xl">{service.title}</h3>
                <p class="mt-5 leading-7 text-muted">{service.text}</p>
                <ul class="mt-auto space-y-3 pt-10">
                  {service.features.map((feature) => (
                    <li class="flex items-center gap-3 border-t border-line pt-3 text-sm font-bold">
                      <i class="fa-solid fa-check text-xs text-brand" aria-hidden="true"></i>
                      {feature}
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="folyamat" class="section-space bg-[#111827] text-white">
      <div class="container-shell">
        <div class="flex flex-col justify-between gap-7 md:flex-row md:items-end">
          <div class="reveal">
            <p class="eyebrow !text-[#76a2ff]">Így dolgozunk</p>
            <h2 class="section-title mt-6">Tiszta folyamat az első beszélgetéstől az indulásig.</h2>
          </div>
          <p class="reveal delay-1 max-w-md leading-7 text-white/65">
            Végig tudni fogja, mi történik a projektben. Rövid egyeztetések, látható haladás, egyértelmű következő lépések.
          </p>
        </div>

        <ol class="mt-16 grid border-l border-t border-white/15 md:grid-cols-2 xl:grid-cols-4">
          {
            process.map(([number, icon, heading, text], index) => (
              <li class={`reveal delay-${Math.min(index + 1, 3)} min-h-72 border-b border-r border-white/15 p-7 lg:p-8`}>
                <div class="flex items-center justify-between">
                  <span class="text-xs font-extrabold tracking-[0.16em] text-[#76a2ff]">{number}</span>
                  <span class="flex size-11 items-center justify-center border border-white/15 text-[#76a2ff]">
                    <i class={`fa-solid ${icon}`} aria-hidden="true"></i>
                  </span>
                </div>
                <h3 class="mt-12 text-xl font-semibold tracking-[-0.025em]">{heading}</h3>
                <p class="mt-4 text-sm leading-7 text-white/60">{text}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section id="referencia" class="section-space">
      <div class="container-shell">
        <div class="grid items-end gap-8 lg:grid-cols-[1fr_auto]">
          <div class="reveal">
            <p class="eyebrow">Kiemelt referencia</p>
            <h2 class="section-title mt-6">Főnix Box Club</h2>
          </div>
          <a href="https://www.fonixboxclub.hu" target="_blank" rel="noopener noreferrer" class="button-secondary reveal">
            Élő weboldal
            <ArrowIcon external />
          </a>
        </div>

        <div class="reveal delay-1 mt-12 overflow-hidden border border-line bg-[#090909] p-2 sm:p-3">
          <img
            src="/images/fonix-reference.webp"
            width="2547"
            height="943"
            alt="A Főnix Box Club általunk készített weboldalának kezdőlapja"
            class="h-auto w-full"
            loading="lazy"
          />
        </div>

        <div class="mt-10 flex flex-col justify-between gap-8 lg:flex-row lg:items-center">
          <div class="reveal">
            <div class="flex items-center gap-4">
              <img src="/images/fonix-logo.webp" width="500" height="500" alt="Főnix Box Club logó" class="size-14 object-contain" loading="lazy" />
              <div>
                <div class="font-extrabold">Főnix Box Club</div>
                <div class="mt-1 text-sm text-muted">Sportegyesület</div>
              </div>
            </div>
            <div class="mt-8 flex flex-wrap gap-2">
              {['Reszponzív weboldal', 'Admin felület', 'Gyors működés', 'Könnyű használat'].map((item) => (
                <span class="border border-line bg-surface px-3 py-2 text-xs font-bold text-muted">{item}</span>
              ))}
            </div>
          </div>

          <div class="reveal delay-1 max-w-xl lg:text-right">
            <h3 class="text-xl font-semibold leading-snug tracking-[-0.025em] md:text-2xl">
              Modern, gyors weboldal saját admin felülettel.
            </h3>
            <p class="mt-3 leading-7 text-muted">Egyszerű használat a látogatóknak és a klubnak is.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="velemenyek" class="section-space border-y border-line bg-surface">
      <div class="container-shell">
        <div class="reveal text-center">
          <p class="eyebrow">Ügyfélvélemények</p>
          <h2 class="section-title mx-auto mt-6">Akik már dolgoztak velünk.</h2>
        </div>

        <div class="mt-14 grid items-start border-l border-t border-line lg:grid-cols-2">
          <blockquote class="reveal flex flex-col self-start border-b border-r border-line bg-white p-7 sm:p-9">
            <i class="fa-solid fa-quote-left text-2xl text-brand" aria-hidden="true"></i>
            <p class="mt-6 text-xl font-medium leading-9 tracking-[-0.02em]">
              „A webes fejlesztések és az online megjelenések nagyban hozzájárultak ahhoz, hogy klubunk egyre több emberhez eljusson.”
            </p>
            <footer class="flex items-center gap-4 pt-10">
              <img src="/images/fonix-logo.webp" width="500" height="500" alt="" class="size-12 object-contain" loading="lazy" />
              <div>
                <div class="font-extrabold">Csaba</div>
                <div class="mt-1 text-sm text-muted">Főnix Box Club</div>
              </div>
            </footer>
          </blockquote>

          <blockquote class="reveal delay-1 flex flex-col self-start border-b border-r border-line bg-white p-7 sm:p-9">
            <i class="fa-solid fa-quote-left text-2xl text-brand" aria-hidden="true"></i>
            <p class="mt-6 text-xl font-medium leading-9 tracking-[-0.02em]">
              „Zoli már a közös munkánk elején gyorsan ráérzett, milyen marketing tartalomra és hirdetésre van szükségem ahhoz, hogy az emberek felfigyeljenek a vállalkozásomra. A frissített marketing anyagoknak és hirdetéseknek köszönhetően érdeklődők is érkeztek.”
            </p>
            <footer class="flex items-center gap-4 pt-10">
              <img src="/images/cleancar-logo.webp" width="500" height="500" alt="" class="size-12 object-contain" loading="lazy" />
              <div>
                <div class="font-extrabold">Ádám</div>
                <div class="mt-1 text-sm text-muted">Cleancar Szolnok</div>
              </div>
            </footer>
          </blockquote>
        </div>
      </div>
    </section>

    <section id="rolunk" class="section-space">
      <div class="container-shell">
        <div class="grid gap-12 lg:grid-cols-[0.78fr_1.22fr] lg:gap-24">
          <div class="reveal">
            <p class="eyebrow">Miért WebsiteBusiness?</p>
            <h2 class="section-title mt-6">Egy fejlesztőcsapat, amely érti az üzleti oldalt is.</h2>
            <p class="section-copy mt-7">
              Kisebb weboldaltól az összetettebb webalkalmazásig ugyanaz a célunk: jól használható, megbízható szoftvert készíteni.
            </p>
          </div>

          <div class="border-t border-line">
            {
              values.map((value, index) => (
                <article class={`reveal delay-${index + 1} grid gap-5 border-b border-line py-9 sm:grid-cols-[3.5rem_1fr]`}>
                  <span class="flex size-12 items-center justify-center bg-[#eaf0ff] text-brand">
                    <i class={`fa-solid ${value.icon}`} aria-hidden="true"></i>
                  </span>
                  <div>
                    <h3 class="text-xl font-semibold tracking-[-0.025em]">{value.title}</h3>
                    <p class="mt-3 max-w-xl leading-7 text-muted">{value.text}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section id="kapcsolat" class="section-space">
      <div class="container-shell">
        <div class="relative overflow-hidden bg-brand px-6 py-14 text-white sm:px-12 sm:py-16 lg:px-20 lg:py-20">
          <div class="absolute right-0 top-0 size-36 translate-x-1/3 -translate-y-1/3 border-[28px] border-white/12"></div>
          <div class="relative grid items-end gap-12 lg:grid-cols-[1fr_auto]">
            <div class="reveal">
              <p class="text-xs font-extrabold uppercase tracking-[0.18em] text-white/70">Indítsuk el</p>
              <h2 class="mt-6 max-w-3xl text-[clamp(2.5rem,5.5vw,5rem)] font-semibold leading-[1.02] tracking-[-0.055em]">
                Van egy ötlete? Nézzük meg, hogyan lesz belőle működő szoftver.
              </h2>
            </div>
            <div class="reveal delay-1 flex min-w-64 flex-col gap-3">
              <a href="tel:+36205694772" class="flex min-h-14 items-center justify-between bg-white px-5 font-extrabold text-ink transition-colors hover:bg-[#edf2ff]">
                <span class="flex items-center gap-3">
                  <i class="fa-solid fa-phone text-brand" aria-hidden="true"></i>
                  +36 20 569 4772
                </span>
                <ArrowIcon />
              </a>
              <a href="mailto:info@websitebusiness.hu" class="flex min-h-14 items-center justify-between border border-white/35 px-5 font-extrabold text-white transition-colors hover:bg-white/10">
                <span class="flex items-center gap-3">
                  <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                  Írjon e-mailt
                </span>
                <ArrowIcon />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-line">
    <div class="container-shell grid gap-10 py-12 md:grid-cols-[1fr_auto] md:items-end">
      <div>
        <a href="#kezdolap" class="inline-flex items-center gap-3" aria-label="WebsiteBusiness főoldal">
          <img src="/images/logo.webp" width="200" height="200" alt="" class="size-10 object-contain" loading="lazy" />
          <span class="text-base font-extrabold tracking-[-0.035em]">WebsiteBusiness</span>
        </a>
        <p class="mt-5 max-w-md text-sm leading-7 text-muted">Egyedi weboldalak és webalkalmazások vállalkozásoknak.</p>
      </div>
      <div class="flex flex-col gap-3 text-sm font-bold text-muted sm:flex-row sm:gap-6">
        <a class="transition-colors hover:text-ink" href="mailto:info@websitebusiness.hu">info@websitebusiness.hu</a>
        <a class="transition-colors hover:text-ink" href="https://www.instagram.com/websitebusinesshu/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a class="transition-colors hover:text-ink" href="https://www.facebook.com/profile.php?id=61566883799064" target="_blank" rel="noopener noreferrer">Facebook</a>
      </div>
    </div>
    <div class="border-t border-line">
      <div class="container-shell flex flex-col gap-2 py-5 text-xs font-semibold text-muted sm:flex-row sm:items-center sm:justify-between">
        <span>© {new Date().getFullYear()} WebsiteBusiness. Minden jog fenntartva.</span>
        <span>Magyarország · Országos együttműködés</span>
      </div>
    </div>
  </footer>
</BaseLayout>
