---
import ArrowIcon from '../components/ArrowIcon.astro';
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    number: '01',
    title: 'Céges weboldalak',
    text: 'Gyors, átlátható és mobilon is kényelmes weboldal, amely bizalmat épít és segíti az ügyfélszerzést.',
    features: ['Egyedi megjelenés', 'Keresőbarát felépítés', 'Gyors betöltés'],
  },
  {
    number: '02',
    title: 'Webalkalmazások',
    text: 'A vállalkozás működésére szabott online rendszer, ha egy egyszerű weboldalnál többre van szükség.',
    features: ['Admin felület', 'Ügyfélportál', 'Egyedi funkciók'],
  },
  {
    number: '03',
    title: 'Továbbfejlesztés',
    text: 'Meglévő weboldalak és rendszerek korszerűsítése, gyorsítása vagy új funkciókkal való bővítése.',
    features: ['Frissítés', 'Automatizálás', 'Hosszú távú támogatás'],
  },
];

const process = [
  ['01', 'Megismerjük a célt', 'Röviden átbeszéljük, mire van szüksége és mit kell megoldania a szoftvernek.'],
  ['02', 'Tervet készítünk', 'Összerakjuk a felépítést, a fő funkciókat és egy átlátható ajánlatot.'],
  ['03', 'Fejlesztünk', 'Folyamatosan mutatjuk az eredményt, így végig látható, hol tart a projekt.'],
  ['04', 'Elindítjuk', 'Tesztelés után élesítjük a rendszert, és a folytatásban sem marad egyedül.'],
];

const values = [
  {
    title: 'Érthetően kommunikálunk',
    text: 'Nincs felesleges szakzsargon. Mindig világos, mi készül, miért és mikorra.',
  },
  {
    title: 'Az üzleti célt nézzük',
    text: 'Nem csak egy szép felületet adunk át. Olyan megoldást építünk, amelynek valódi szerepe van a működésben.',
  },
  {
    title: 'Továbbfejleszthető alapot adunk',
    text: 'A mai kisebb projektből később nagyobb rendszer is lehet, teljes újrakezdés nélkül.',
  },
];

const title = 'Egyedi weboldal és webalkalmazás fejlesztés | WebsiteBusiness';
const description =
  'Modern céges weboldalakat, webalkalmazásokat és egyedi webes rendszereket fejlesztünk vállalkozásoknak. Gyors, átlátható, hosszú távú megoldások.';
---

<BaseLayout {title} {description}>
  <Header />

  <main>
    <section id="kezdolap" class="relative overflow-hidden bg-[#f3f5f7] pt-20">
      <div class="container-shell py-5 md:py-7">
        <div class="reveal flex items-center justify-between border-b border-[#cfd5dc] pb-5 text-[0.65rem] font-extrabold uppercase tracking-[0.19em] text-muted md:pb-6">
          <span>Egyedi szoftverfejlesztés</span>
          <span class="hidden items-center gap-2 sm:flex">
            <span class="size-1.5 bg-brand"></span>
            Digitális standard · 2026
          </span>
          <span class="sm:hidden">2026</span>
        </div>

        <div class="grid lg:grid-cols-[minmax(0,1.58fr)_minmax(20rem,0.72fr)]">
          <div class="flex min-h-[41rem] flex-col border-[#cfd5dc] py-12 lg:border-r lg:py-16 lg:pr-16 xl:min-h-[45rem] xl:pr-20">
            <div>
              <p class="reveal text-sm font-bold text-brand">Weboldalak · Webalkalmazások · Egyedi rendszerek</p>
              <h1
                class="reveal delay-1 mt-8 max-w-4xl text-[clamp(3.5rem,7.25vw,7rem)] font-semibold leading-[0.91] tracking-[-0.075em]"
                aria-label="2026-ra tervezve. Önre szabva."
              >
                2026-ra
                <span class="block text-brand">tervezve.</span>
                Önre szabva.
              </h1>
            </div>

            <div class="mt-auto grid gap-8 pt-12 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
              <p class="reveal delay-2 max-w-xl text-lg leading-8 text-muted md:text-xl md:leading-9">
                Modern weboldalakat és webalkalmazásokat építünk, amelyek ma meggyőzőek, holnap pedig gond nélkül továbbfejleszthetők.
              </p>
              <div class="reveal delay-3 flex flex-col gap-3 sm:flex-row md:flex-col">
                <a href="#kapcsolat" class="button-primary min-w-56">
                  Indítsuk el a projektet
                  <ArrowIcon />
                </a>
                <a href="#referencia" class="group inline-flex min-h-12 items-center justify-between gap-8 border-b border-[#aeb6c1] px-1 text-sm font-extrabold transition-colors hover:border-ink">
                  Eddigi munkánk
                  <span class="text-brand transition-transform group-hover:translate-x-1"><ArrowIcon /></span>
                </a>
              </div>
            </div>
          </div>

          <div class="reveal delay-2 flex min-h-[34rem] flex-col bg-brand p-7 text-white sm:p-9 lg:min-h-[41rem] lg:p-10 xl:min-h-[45rem]">
            <div class="flex items-center justify-between border-b border-white/30 pb-5 text-[0.65rem] font-extrabold uppercase tracking-[0.19em]">
              <span>WB / Edition</span>
              <span>HU — 26</span>
            </div>

            <div class="flex flex-1 items-center py-10">
              <div class="w-full">
                <div class="flex items-start justify-between">
                  <span class="mt-3 text-xs font-bold uppercase tracking-[0.16em] text-white/65">Current<br />standard</span>
                  <span class="size-3 bg-white"></span>
                </div>
                <div class="mt-4 text-[clamp(8rem,17vw,14rem)] font-semibold leading-[0.72] tracking-[-0.095em]">
                  20
                  <span class="block text-right">26</span>
                </div>
              </div>
            </div>

            <div class="border-t border-white/30 pt-6">
              <p class="max-w-xs text-xl font-semibold leading-snug tracking-[-0.03em]">
                Nem a tegnapi internetre építünk.
              </p>
              <div class="mt-7 grid grid-cols-2 gap-x-5 gap-y-4 text-xs font-bold text-white/75">
                <span>01 · Gyors</span>
                <span>02 · Átlátható</span>
                <span>03 · Bővíthető</span>
                <span>04 · Mobilra kész</span>
              </div>
            </div>
          </div>
        </div>

        <div class="reveal delay-3 grid border-x border-b border-[#cfd5dc] bg-white sm:grid-cols-2 lg:grid-cols-4">
          {
            ['Céges weboldal', 'Webalkalmazás', 'Admin felület', 'Egyedi funkciók'].map((item, index) => (
              <div class="flex items-center gap-4 border-t border-[#cfd5dc] px-5 py-5 sm:border-r lg:border-t-0">
                <span class="text-[0.65rem] font-extrabold tracking-[0.16em] text-brand">0{index + 1}</span>
                <span class="text-sm font-extrabold">{item}</span>
              </div>
            ))
          }
        </div>
      </div>

      <div class="border-y border-line bg-white">
        <div class="container-shell flex flex-col items-start justify-between gap-5 py-5 sm:flex-row sm:items-center">
          <span class="text-xs font-extrabold uppercase tracking-[0.18em] text-muted">Már velünk dolgozott</span>
          <a href="#referencia" class="group flex items-center gap-3 text-sm font-extrabold">
            <img src="/images/fonix-logo.webp" width="500" height="500" alt="" class="size-9 object-contain" />
            Főnix Box Club
            <span class="text-brand transition-transform group-hover:translate-x-1"><ArrowIcon /></span>
          </a>
        </div>
      </div>
    </section>

    <section id="szolgaltatasok" class="section-space">
      <div class="container-shell">
        <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr] lg:gap-20">
          <div class="reveal">
            <p class="eyebrow">Amiben segítünk</p>
            <h2 class="section-title mt-6">A megfelelő megoldás, felesleges körök nélkül.</h2>
          </div>
          <p class="section-copy reveal delay-1 lg:mt-10">
            Nem sablont adunk el. Megértjük, mire van szüksége a vállalkozásnak, és arra építjük fel a weboldalt vagy a rendszert.
          </p>
        </div>

        <div class="mt-16 grid border-l border-t border-line md:grid-cols-3">
          {
            services.map((service, index) => (
              <article class={`reveal delay-${index + 1} flex min-h-[29rem] flex-col border-b border-r border-line p-7 transition-colors hover:bg-surface lg:p-9`}>
                <div class="flex items-center justify-between">
                  <span class="text-xs font-extrabold tracking-[0.16em] text-brand">{service.number}</span>
                  <span class="size-2 bg-brand"></span>
                </div>
                <h3 class="mt-16 text-2xl font-semibold tracking-[-0.035em] lg:text-3xl">{service.title}</h3>
                <p class="mt-5 leading-7 text-muted">{service.text}</p>
                <ul class="mt-auto space-y-3 pt-10">
                  {service.features.map((feature) => (
                    <li class="flex items-center gap-3 border-t border-line pt-3 text-sm font-bold">
                      <svg viewBox="0 0 20 20" class="size-4 fill-none stroke-brand stroke-2" aria-hidden="true">
                        <path d="m4 10 3.2 3.2L16 5.8" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="folyamat" class="section-space bg-[#111827] text-white">
      <div class="container-shell">
        <div class="flex flex-col justify-between gap-7 md:flex-row md:items-end">
          <div class="reveal">
            <p class="eyebrow !text-[#76a2ff]">Így dolgozunk</p>
            <h2 class="section-title mt-6">Tiszta folyamat az első beszélgetéstől az indulásig.</h2>
          </div>
          <p class="reveal delay-1 max-w-md leading-7 text-white/65">
            Végig tudni fogja, mi történik a projektben. Rövid egyeztetések, látható haladás, egyértelmű következő lépések.
          </p>
        </div>

        <ol class="mt-16 grid border-l border-t border-white/15 md:grid-cols-2 xl:grid-cols-4">
          {
            process.map(([number, heading, text], index) => (
              <li class={`reveal delay-${Math.min(index + 1, 3)} min-h-72 border-b border-r border-white/15 p-7 lg:p-8`}>
                <span class="text-xs font-extrabold tracking-[0.16em] text-[#76a2ff]">{number}</span>
                <h3 class="mt-16 text-xl font-semibold tracking-[-0.025em]">{heading}</h3>
                <p class="mt-4 text-sm leading-7 text-white/60">{text}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section id="referencia" class="section-space">
      <div class="container-shell">
        <div class="grid items-end gap-8 lg:grid-cols-[1fr_auto]">
          <div class="reveal">
            <p class="eyebrow">Kiemelt referencia</p>
            <h2 class="section-title mt-6">Főnix Box Club</h2>
          </div>
          <a href="https://www.fonixboxclub.hu" target="_blank" rel="noopener noreferrer" class="button-secondary reveal">
            Élő weboldal
            <ArrowIcon external />
          </a>
        </div>

        <div class="reveal delay-1 mt-12 overflow-hidden border border-line bg-[#090909] p-2 sm:p-3">
          <img
            src="/images/fonix-reference.webp"
            width="2547"
            height="943"
            alt="A Főnix Box Club általunk készített weboldalának kezdőlapja"
            class="h-auto w-full"
            loading="lazy"
          />
        </div>

        <div class="mt-12 grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:gap-24">
          <div class="reveal">
            <div class="flex items-center gap-4">
              <img src="/images/fonix-logo.webp" width="500" height="500" alt="Főnix Box Club logó" class="size-14 object-contain" loading="lazy" />
              <div>
                <div class="font-extrabold">Főnix Box Club</div>
                <div class="mt-1 text-sm text-muted">Sportegyesület</div>
              </div>
            </div>
            <div class="mt-8 flex flex-wrap gap-2">
              {['Reszponzív weboldal', 'Admin felület', 'Gyors működés', 'Könnyű használat'].map((item) => (
                <span class="border border-line bg-surface px-3 py-2 text-xs font-bold text-muted">{item}</span>
              ))}
            </div>
          </div>

          <div class="reveal delay-1">
            <h3 class="text-2xl font-semibold leading-snug tracking-[-0.035em] md:text-3xl">
              Modern weboldal, amely egyszerűvé teszi a klub bemutatását és a tartalmak kezelését.
            </h3>
            <p class="mt-6 max-w-2xl leading-8 text-muted">
              A Főnix Box Club számára egy mobilbarát, gyors weboldalt és saját admin felületet készítettünk. A látogatók könnyen megtalálják a fontos információkat, a klub pedig önállóan frissítheti a tartalmakat.
            </p>
            <blockquote class="mt-10 border-l-2 border-brand pl-6">
              <p class="text-lg font-medium leading-8">
                „A webes fejlesztések és az online megjelenések nagyban hozzájárultak ahhoz, hogy klubunk egyre több emberhez eljusson.”
              </p>
              <footer class="mt-4 text-sm font-bold text-muted">Csaba · Főnix Box Club</footer>
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <section id="rolunk" class="section-space border-y border-line bg-surface">
      <div class="container-shell">
        <div class="grid gap-12 lg:grid-cols-[0.78fr_1.22fr] lg:gap-24">
          <div class="reveal">
            <p class="eyebrow">Miért WebsiteBusiness?</p>
            <h2 class="section-title mt-6">Egy fejlesztőcsapat, amely érti az üzleti oldalt is.</h2>
            <p class="section-copy mt-7">
              Kisebb weboldaltól az összetettebb webalkalmazásig ugyanaz a célunk: jól használható, megbízható szoftvert készíteni.
            </p>
          </div>

          <div class="border-t border-line">
            {
              values.map((value, index) => (
                <article class={`reveal delay-${index + 1} grid gap-4 border-b border-line py-8 sm:grid-cols-[3rem_1fr]`}>
                  <span class="text-xs font-extrabold tracking-[0.16em] text-brand">0{index + 1}</span>
                  <div>
                    <h3 class="text-xl font-semibold tracking-[-0.025em]">{value.title}</h3>
                    <p class="mt-3 max-w-xl leading-7 text-muted">{value.text}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section id="kapcsolat" class="section-space">
      <div class="container-shell">
        <div class="relative overflow-hidden bg-brand px-6 py-14 text-white sm:px-12 sm:py-16 lg:px-20 lg:py-20">
          <div class="absolute right-0 top-0 size-36 translate-x-1/3 -translate-y-1/3 border-[28px] border-white/12"></div>
          <div class="relative grid items-end gap-12 lg:grid-cols-[1fr_auto]">
            <div class="reveal">
              <p class="text-xs font-extrabold uppercase tracking-[0.18em] text-white/70">Indítsuk el</p>
              <h2 class="mt-6 max-w-3xl text-[clamp(2.5rem,5.5vw,5rem)] font-semibold leading-[1.02] tracking-[-0.055em]">
                Van egy ötlete? Nézzük meg, hogyan lesz belőle működő szoftver.
              </h2>
            </div>
            <div class="reveal delay-1 flex min-w-64 flex-col gap-3">
              <a href="tel:+36205694772" class="flex min-h-14 items-center justify-between bg-white px-5 font-extrabold text-ink transition-colors hover:bg-[#edf2ff]">
                +36 20 569 4772
                <ArrowIcon />
              </a>
              <a href="mailto:info@websitebusiness.hu" class="flex min-h-14 items-center justify-between border border-white/35 px-5 font-extrabold text-white transition-colors hover:bg-white/10">
                Írjon e-mailt
                <ArrowIcon />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-line">
    <div class="container-shell grid gap-10 py-12 md:grid-cols-[1fr_auto] md:items-end">
      <div>
        <a href="#kezdolap" class="inline-flex items-center gap-3" aria-label="WebsiteBusiness főoldal">
          <img src="/images/logo.webp" width="200" height="200" alt="" class="size-10 object-contain" loading="lazy" />
          <span class="text-base font-extrabold tracking-[-0.035em]">WebsiteBusiness</span>
        </a>
        <p class="mt-5 max-w-md text-sm leading-7 text-muted">Egyedi weboldalak és webalkalmazások vállalkozásoknak.</p>
      </div>
      <div class="flex flex-col gap-3 text-sm font-bold text-muted sm:flex-row sm:gap-6">
        <a class="transition-colors hover:text-ink" href="mailto:info@websitebusiness.hu">info@websitebusiness.hu</a>
        <a class="transition-colors hover:text-ink" href="https://www.instagram.com/websitebusinesshu/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a class="transition-colors hover:text-ink" href="https://www.facebook.com/profile.php?id=61566883799064" target="_blank" rel="noopener noreferrer">Facebook</a>
      </div>
    </div>
    <div class="border-t border-line">
      <div class="container-shell flex flex-col gap-2 py-5 text-xs font-semibold text-muted sm:flex-row sm:items-center sm:justify-between">
        <span>© {new Date().getFullYear()} WebsiteBusiness. Minden jog fenntartva.</span>
        <span>Magyarország · Országos együttműködés</span>
      </div>
    </div>
  </footer>
</BaseLayout>
