---
import Header from '../components/Header.astro';
import LandingPage from '../components/LandingPage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const content = {
  hero: {
    eyebrow: 'Weboldal készítés · landing page · egyedi rendszer',
    lines: [
      { text: 'Weboldal készítés.' },
      { text: 'Üzleti céllal.', accent: true },
    ],
    lead: 'Céges weboldalak, landing page-ek és egyedi rendszerek — több jó megkereséshez.',
    primaryCta: 'Beszéljük át a projektet',
    secondaryCta: 'Megnézem a megoldásokat',
    note: 'Kötetlen első egyeztetés · válasz 1 munkanapon belül',
    flowLabels: ['érthető ajánlat', 'bizalom', 'következő lépés'],
    ticker: ['Weboldal', 'Landing page', 'Egyedi rendszer', 'Érthető ajánlat', 'Tiszta működés'],
  },
  diagnostic: {
    eyebrow: 'Először a helyzetet nézzük meg',
    title: 'A weboldalad segít dönteni — vagy útban van.',
    intro: 'Megkeressük, hol vész el az érdeklődő figyelme vagy a csapat ideje.',
    items: [
      {
        number: '01',
        question: 'Van weboldalad, mégsem hoz elég megkeresést?',
        answer: 'Ha az ajánlat nem egyértelmű, nincs bizalom vagy nehéz továbblépni, a látogató továbbáll.',
      },
      {
        number: '02',
        question: 'Kampányhoz kell fókuszált landing page?',
        answer: 'Egy jó landing page egy döntéshez vezeti az érdeklődőt, nem próbál mindent elmondani.',
      },
      {
        number: '03',
        question: 'Túl sok a kézi kör Excelben és e-mailben?',
        answer: 'Egy jól átgondolt belső rendszer rövidíti a lassító, ismétlődő munkát.',
      },
    ],
  },
  solutions: {
    eyebrow: 'Amit felépítünk',
    title: 'Két út. Egy cél: könnyebb növekedés.',
    intro: 'Akár a láthatóságot, akár a működést tesszük rendbe, üzleti helyzetből indulunk.',
    items: [
      {
        kind: 'web',
        number: '01',
        outcome: 'Több jó megkeresés',
        service: 'Weboldal és landing page',
        title: 'Felület, ami irányt ad.',
        text: 'Megtervezzük, mit értsen meg a látogató, majd felépítjük hozzá az oldalt és a következő lépést.',
        bullets: ['Ajánlat és üzenet', 'Struktúra', 'Gyors, mobilra tervezett oldal'],
        url: '/weboldal-keszites/',
        linkLabel: 'Weboldal készítés részletei',
      },
      {
        kind: 'system',
        number: '02',
        outcome: 'Kevesebb kézi kör',
        service: 'Egyedi webfejlesztés',
        title: 'Kevesebb kézi kör. Jobb működés.',
        text: 'Ügyfélportál, admin vagy adatkapcsolat: a napi folyamatból indulunk, nem kész dobozból.',
        bullets: ['Folyamattérkép', 'Prototípus', 'Egyedi webalkalmazás'],
        url: '/egyedi-webfejlesztes/',
        linkLabel: 'Egyedi webfejlesztés részletei',
      },
    ],
  },
  specificSolutions: {
    eyebrow: 'Konkrét helyzetekre',
    title: 'A problémádhoz illő első lépés.',
    intro: 'Nem minden vállalkozásnak ugyanaz az oldal vagy rendszer kell. Válaszd azt a helyzetet, amely most a legközelebb áll hozzád.',
    items: [
      { href: '/weboldal-keszites-kisvallalkozasoknak/', title: 'Weboldal készítés kisvállalkozásoknak', text: 'Gyors, hiteles és bővíthető céges online jelenlét kisebb vállalkozásoknak.' },
      { href: '/weboldal-felujitas-vallalkozasoknak/', title: 'Weboldal felújítás vállalkozásoknak', text: 'Elavult tartalom, lassú mobilos oldal és gyenge ajánlatkérési út újragondolása.' },
      { href: '/landing-page-keszites/', title: 'Landing page készítés hirdetéshez', text: 'Google Ads vagy Meta kampányhoz illesztett, fókuszált és mérhető céloldal.' },
      { href: '/egyedi-admin-felulet-fejlesztes/', title: 'Egyedi admin felület fejlesztés', text: 'Széteső Excel- és e-mail-folyamatok helyett átlátható belső rendszer.' },
      { href: '/ugyfelportal-fejlesztes/', title: 'Ügyfélportál fejlesztés', text: 'Biztonságos önkiszolgáló felület státuszokhoz, fájlokhoz és ügyintézéshez.' },
    ],
  },
  work: {
    eyebrow: 'Valódi munka',
    title: 'Főnix Box Club — karakteres online jelenlét.',
    intro: 'A weboldal átadja a klub hangulatát, és gyors utat ad az információkhoz és a kapcsolathoz.',
    liveLabel: 'Megnézem az élő weboldalt',
    imageAlt: 'A Főnix Box Club számára készült weboldal kezdőlapja',
    client: 'Főnix Box Club',
    clientType: 'Sportegyesület · weboldal + admin',
    labels: ['Kiinduló helyzet', 'A feladat', 'Megoldás'],
    details: [
      'A klub karakterét online is következetesen kellett megmutatni.',
      'Gyors út a fontos információkhoz és a kapcsolathoz.',
      'Karakteres, mobilbarát oldal és könnyen kezelhető admin.',
    ],
    quote: 'A webes fejlesztések és az online megjelenések nagyban hozzájárultak ahhoz, hogy klubunk egyre több emberhez eljusson.',
    author: 'Csaba · Főnix Box Club',
  },
  process: {
    eyebrow: 'Így lesz az ötletből működő eszköz',
    title: 'Egy projektnek nem kell ködösnek lennie.',
    intro: 'Minden lépésnél látod, min dolgozunk és mi lesz belőle.',
    steps: [
      { number: '01', title: 'Megértjük a helyzetet', text: 'A célt, a célközönséget és az elakadást értjük meg először.', outcome: 'Közös irány' },
      { number: '02', title: 'Megrajzoljuk a megoldást', text: 'Az oldal- vagy rendszertervet a fejlesztés előtt tisztázzuk.', outcome: 'Tiszta terv' },
      { number: '03', title: 'Megépítjük és teszteljük', text: 'Valódi használatra fejlesztünk, majd mobilon és asztali gépen is tesztelünk.', outcome: 'Használható eszköz' },
      { number: '04', title: 'Élesítünk és átadunk', text: 'Olyan alapot adunk át, amely később is bővíthető.', outcome: 'Bővíthető alap' },
    ],
  },
  approach: {
    eyebrow: 'A szemléletünk',
    title: 'Nem sablont adunk. Jó irányt.',
    intro: 'A cél: érthetőbb ajánlat, jobb ügyfélút vagy kevesebb kézi munka.',
    note: 'Azokkal beszélsz, akik a megoldáson dolgoznak — gyors, követhető döntésekkel.',
    principles: [
      { title: 'A látogató gyorsan érti a lényeget.', text: 'Az első képernyő a vevő helyzetéről és a következő lépésről szól.' },
      { title: 'A csapatnak is könnyű használni.', text: 'Az admin akkor jó, ha egyszerűbbé teszi a napi munkát.' },
      { title: 'A rendszer együtt nő a céggel.', text: 'Először a fontos lépést építjük meg, később bővíthetően.' },
    ],
  },
  testimonial: {
    eyebrow: 'Visszajelzés',
    title: 'Jó együttműködés, már az elejétől.',
    quote: '„Zoli már a közös munkánk elején gyorsan ráérzett, milyen marketing tartalomra és hirdetésre van szükségem ahhoz, hogy az emberek felfigyeljenek a vállalkozásomra.”',
    author: 'Ádám',
    company: 'Cleancar Szolnok',
  },
  faq: {
    eyebrow: 'Gyakori kérdések',
    title: 'Röviden, mielőtt beszélünk.',
    items: [
      { question: 'Van értelme beszélni, ha már van weboldalunk?', answer: 'Igen. Az első egyeztetésen kiderül, hogy az ajánlat, a szerkezet, a sebesség vagy a kapcsolatfelvétel szorul-e javításra.' },
      { question: 'Mikor kell egyedi rendszert fejleszteni?', answer: 'Ha egy ismétlődő folyamat túl sok kézi munkát vagy hibát okoz. Először tisztázzuk a folyamatot, utána javaslunk fejlesztést.' },
      { question: 'Segítetek a szövegben is?', answer: 'Igen. Közösen tisztázzuk az ajánlatot, a célcsoportot és a fő üzeneteket.' },
      { question: 'Mennyibe kerül egy projekt?', answer: 'A céloktól, oldalak és funkciók számától függ. Az első egyeztetés után tiszta első lépést és ajánlatot kapsz.' },
    ],
  },
  contact: {
    eyebrow: 'Első beszélgetés',
    title: 'A weboldalad többet is hozhat.',
    text: 'Nézzük meg a legjobb következő lépést — weboldal, landing page vagy egyedi fejlesztés.',
    emailCta: 'Írok a projektről',
    phoneCta: 'Inkább felhívom',
    emailSubject: 'Első egyeztetés a WebsiteBusiness-szel',
  },
  footer: {
    text: 'Weboldalak és egyedi rendszerek növekvő vállalkozásoknak.',
    legal: 'Adatkezelési tájékoztató',
    locale: 'Minden jog fenntartva.',
    country: 'Magyarország · országos együttműködés',
  },
};

const title = 'Weboldal készítés és webfejlesztés vállalkozásoknak | WebsiteBusiness';
const description = 'Konverzióra tervezett weboldal készítés, landing page készítés és egyedi webalkalmazás-fejlesztés vállalkozásoknak. Beszéljük át a projektet.';
const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout {title} {description}>
  <Header />
  <LandingPage {content} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
</BaseLayout>
