---
import ArrowIcon from './ArrowIcon.astro';

interface Props {
  lang?: 'hu' | 'en';
  page?: 'home' | 'service';
}

const { lang = 'hu', page = 'home' } = Astro.props;
const isEnglish = lang === 'en';
const home = isEnglish ? '/en/#home' : '/#kezdolap';
const sectionLink = (huId: string, enId: string) => {
  const id = isEnglish ? enId : huId;
  if (page === 'home') return `#${id}`;
  return `${isEnglish ? '/en/' : '/'}#${id}`;
};
const contact = sectionLink('kapcsolat', 'contact');
const links = isEnglish
  ? [
      ['Solutions', sectionLink('megoldasok', 'solutions')],
      ['Work', sectionLink('munka', 'work')],
      ['Process', sectionLink('folyamat', 'process')],
      ['About', sectionLink('rolunk', 'about')],
    ]
  : [
      ['Megoldások', sectionLink('megoldasok', 'solutions')],
      ['Munkák', sectionLink('munka', 'work')],
      ['Folyamat', sectionLink('folyamat', 'process')],
      ['Rólunk', sectionLink('rolunk', 'about')],
    ];
---

<header class="site-header fixed inset-x-0 top-0 z-50 border-b border-line/80 backdrop-blur-md" data-header>
  <div class="container-shell flex h-20 items-center justify-between max-md:h-18">
    <a href={home} class="flex items-center" aria-label={isEnglish ? 'WebsiteBusiness homepage' : 'WebsiteBusiness főoldal'}>
      <img
        src="/images/header-logo.webp"
        width="1223"
        height="147"
        alt="WebsiteBusiness"
        class="h-auto w-[10.7rem] object-contain sm:w-[12.4rem]"
        fetchpriority="high"
      />
    </a>

    <nav class="hidden items-center gap-6 xl:flex" aria-label={isEnglish ? 'Main navigation' : 'Fő navigáció'}>
      {links.map(([label, href]) => (
        <a class="text-[0.82rem] font-bold text-muted transition-colors hover:text-ink" href={href}>{label}</a>
      ))}
      <a class="border-l border-line pl-5 font-mono text-[0.68rem] font-bold tracking-[0.12em] text-brand" href={isEnglish ? '/' : '/en/'}>
        {isEnglish ? 'HU' : 'EN'}
      </a>
    </nav>

    <a href={contact} class="button-primary max-xl:!hidden !min-h-11 !px-5 xl:!inline-flex">
      {isEnglish ? "Let's talk" : 'Beszéljünk'}
      <ArrowIcon />
    </a>

    <button
      type="button"
      class="relative flex size-11 items-center justify-center border border-line bg-transparent xl:hidden"
      aria-label={isEnglish ? 'Open menu' : 'Menü megnyitása'}
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-open-label={isEnglish ? 'Open menu' : 'Menü megnyitása'}
      data-close-label={isEnglish ? 'Close menu' : 'Menü bezárása'}
      data-menu-button
    >
      <span class="absolute h-px w-5 -translate-y-1.5 bg-ink transition-transform" data-menu-line="top"></span>
      <span class="absolute h-px w-5 translate-y-1.5 bg-ink transition-transform" data-menu-line="bottom"></span>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-line bg-paper xl:hidden" data-mobile-menu>
    <nav class="container-shell flex min-h-[calc(100svh-4.5rem)] flex-col py-7" aria-label={isEnglish ? 'Mobile navigation' : 'Mobil navigáció'}>
      <div class="flex flex-col border-t border-line">
        {links.map(([label, href]) => (
          <a class="border-b border-line py-5 text-2xl font-semibold tracking-[-0.045em]" href={href}>{label}</a>
        ))}
        <a class="border-b border-line py-5 font-mono text-sm font-bold tracking-[0.1em] text-brand" href={isEnglish ? '/' : '/en/'}>
          {isEnglish ? 'Magyar' : 'English'}
        </a>
      </div>
      <a href={contact} class="button-primary mt-auto w-full">
        {isEnglish ? 'Discuss a project' : 'Beszéljük át a projektet'}
        <ArrowIcon />
      </a>
    </nav>
  </div>
</header>

<script>
  const button = document.querySelector<HTMLButtonElement>('[data-menu-button]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const topLine = document.querySelector<HTMLElement>('[data-menu-line="top"]');
  const bottomLine = document.querySelector<HTMLElement>('[data-menu-line="bottom"]');

  const setMenu = (open: boolean) => {
    if (!button || !menu || !topLine || !bottomLine) return;

    button.setAttribute('aria-expanded', String(open));
    button.setAttribute('aria-label', open ? button.dataset.closeLabel ?? 'Close menu' : button.dataset.openLabel ?? 'Open menu');
    menu.classList.toggle('hidden', !open);
    topLine.classList.toggle('!translate-y-0', open);
    topLine.classList.toggle('rotate-45', open);
    bottomLine.classList.toggle('!translate-y-0', open);
    bottomLine.classList.toggle('-rotate-45', open);
    document.body.classList.toggle('menu-open', open);
  };

  button?.addEventListener('click', () => {
    setMenu(button.getAttribute('aria-expanded') !== 'true');
  });

  menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setMenu(false)));

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1280) setMenu(false);
  });
</script>
