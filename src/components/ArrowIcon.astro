---
interface Props {
  external?: boolean;
}

const { external = false } = Astro.props;
---

{
  external ? (
    <svg viewBox="0 0 20 20" aria-hidden="true" class="size-4 fill-none stroke-current stroke-[1.8]">
      <path d="M6 14 14 6M7.5 6H14v6.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  ) : (
    <svg viewBox="0 0 20 20" aria-hidden="true" class="size-4 fill-none stroke-current stroke-[1.8]">
      <path d="M4 10h12M11.5 5.5 16 10l-4.5 4.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
