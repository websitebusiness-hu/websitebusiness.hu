---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  lang?: 'hu' | 'en';
  noindex?: boolean;
  hasLanguageAlternates?: boolean;
}

const { title, description, lang = 'hu', noindex = false, hasLanguageAlternates = true } = Astro.props;
const siteUrl = Astro.site ?? new URL('https://websitebusiness.hu');
const canonical = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL('/images/og-image.png', siteUrl);
const huUrl = new URL('/', siteUrl);
const enUrl = new URL('/en/', siteUrl);
const organizationName = 'WebsiteBusiness';
const isHomePage = Astro.url.pathname === '/' || Astro.url.pathname === '/en/';
const robotsContent = noindex
  ? 'noindex, follow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const services =
  lang === 'en'
    ? [
        'Business website development',
        'Landing page development',
        'Custom web development',
        'Web application development',
      ]
    : [
        'Weboldal készítés vállalkozásoknak',
        'Landing page készítés',
        'Egyedi webfejlesztés',
        'Webalkalmazás fejlesztés',
      ];

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#organization`,
      name: organizationName,
      url: siteUrl.href,
      logo: new URL('/images/logo.webp', siteUrl).href,
      image: ogImage.href,
      description: lang === 'en'
        ? 'Business websites, landing pages and custom web applications for growing companies.'
        : 'Üzleti célú weboldalak, landing oldalak és egyedi webalkalmazások vállalkozásoknak.',
      email: 'info@websitebusiness.hu',
      telephone: '+36 20 569 4772',
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'sales',
        email: 'info@websitebusiness.hu',
        telephone: '+36 20 569 4772',
        availableLanguage: ['Hungarian', 'English'],
      },
      sameAs: [
        'https://www.instagram.com/websitebusinesshu/',
        'https://www.facebook.com/profile.php?id=61566883799064',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      name: organizationName,
      url: siteUrl.href,
      inLanguage: ['hu-HU', 'en'],
      publisher: {
        '@id': `${siteUrl}#organization`,
      },
    },
    ...(isHomePage
      ? [{
          '@type': 'ProfessionalService',
          '@id': `${siteUrl}#service`,
          name: organizationName,
          url: siteUrl.href,
          image: ogImage.href,
          description,
          email: 'info@websitebusiness.hu',
          telephone: '+36 20 569 4772',
          areaServed: {
            '@type': 'Country',
            name: lang === 'en' ? 'Hungary' : 'Magyarország',
          },
          availableLanguage: ['Hungarian', 'English'],
          serviceType: services,
          provider: {
            '@id': `${siteUrl}#organization`,
          },
        }]
      : []),
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f7f4ee" />
    <meta name="color-scheme" content="light" />
    <meta name="author" content={organizationName} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {
      hasLanguageAlternates && (
        <>
          <link rel="alternate" hreflang="hu-HU" href={huUrl.href} />
          <link rel="alternate" hreflang="en" href={enUrl.href} />
          <link rel="alternate" hreflang="x-default" href={huUrl.href} />
        </>
      )
    }

    <link rel="icon" href="/favicon/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'hu_HU'} />
    {hasLanguageAlternates && (
      <meta property="og:locale:alternate" content={lang === 'en' ? 'hu_HU' : 'en_US'} />
    )}
    <meta property="og:site_name" content={organizationName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:secure_url" content={ogImage.href} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content={lang === 'en' ? 'WebsiteBusiness websites and custom web applications' : 'WebsiteBusiness weboldal készítés, landing page készítés és egyedi webfejlesztés'}
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
    <meta name="twitter:image:alt" content={lang === 'en' ? 'WebsiteBusiness websites and custom web applications' : 'WebsiteBusiness weboldal készítés vállalkozásoknak'} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body class="font-sans antialiased">
    <slot />
    <CookieConsent {lang} />
  </body>
</html>
